{
  "name": "whale-ci",
  "version": "0.2.4",
  "description": "Continuous integration with linked docker containers",
  "type": "module",
  "engines": {
    "node": ">=22.18"
  },
  "bin": {
    "whale-ci": "./dist/src/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/lib/index.d.ts",
      "default": "./dist/lib/index.js"
    }
  },
  "scripts": {
    "start": "node src/cli.ts",
    "test": "node --test",
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "license": "MIT",
  "dependencies": {
    "cmd-ts": "^0.15.0",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.7.0"
  }
}
